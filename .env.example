# ─────────────────────────────────────────────────────────────────────────────
# SERVER secrets (used by /server — never exposed to the browser)
# ─────────────────────────────────────────────────────────────────────────────

# Kapa API key — admin panel → API Keys → create. Used by server/agent-session.
KAPA_API_KEY=your-kapa-api-key

# Which website is allowed to call these endpoints (a browser security check
# called CORS). A browser will block a page from calling your backend on a
# different domain unless the backend says that page's origin is allowed here.
#   "*"                        = any site may call it (fine for local dev)
#   https://www.yoursite.com   = only your site (recommended in production)
# If the widget and this backend are served from the same domain, CORS doesn't
# apply and this value is ignored.
ALLOWED_ORIGIN=*

# ── Booking delivery (server/book-lead) ──────────────────────────────────────
# How "book a call" leads are delivered: email | webhook | hubspot | salesforce
BOOKING_MODE=email

# If BOOKING_MODE=email (Resend — free tier, get a key at resend.com):
RESEND_API_KEY=your-resend-api-key
BOOKING_EMAIL_TO=sales@yourcompany.com
# Optional sender; defaults to Resend's sandbox address for testing.
BOOKING_EMAIL_FROM=onboarding@resend.dev

# If BOOKING_MODE=webhook:
# BOOKING_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxxx/

# If BOOKING_MODE=hubspot — Private App token with scopes:
#   crm.objects.contacts.write, crm.objects.companies.read, crm.objects.leads.write
# HUBSPOT_ACCESS_TOKEN=pat-xxxx

# If BOOKING_MODE=salesforce:
# SALESFORCE_INSTANCE_URL=https://yourorg.my.salesforce.com
# SALESFORCE_ACCESS_TOKEN=your-oauth-access-token
# SALESFORCE_API_VERSION=v60.0   # optional

# ─────────────────────────────────────────────────────────────────────────────
# CLIENT ids (NOT secret — also passed to ProductSelector.init on the host page)
# Used by the local dev playground (index.html).
# admin panel → Projects (project id) and Integrations → Agent Integration.
# ─────────────────────────────────────────────────────────────────────────────
PROJECT_ID=your-kapa-project-id
INTEGRATION_ID=your-kapa-integration-id
